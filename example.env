# ==============================================================================
# career-agent-email-cover — Environment Variable Reference
# ==============================================================================
# Copy this file to .env and fill in your values for local development.
#
#   cp example.env .env
#
# .env is listed in .gitignore — it will NOT be committed to the repository.
# For GitHub Actions, set these as Secrets or Variables in the Actions settings.
# ==============================================================================


# ------------------------------------------------------------------------------
# REQUIRED — Must be set before running anything
# ------------------------------------------------------------------------------

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Full GCP service-account JSON as a single-line string.
# How to get it:
#   1. GCP Console → IAM & Admin → Service Accounts → Create
#   2. Add roles: Editor on Sheets, Editor on Drive (or scoped roles)
#   3. Create JSON key → download → paste entire file content here
GOOGLE_SERVICE_ACCOUNT=

# Exact name of the Google Spreadsheet to read from
GOOGLE_SHEET_NAME=Job Applications

# Top-level Google Drive folder name where outputs will be organized
# Structure created: <GOOGLE_DRIVE_PARENT_FOLDER>/<CompanyName>/<files>
GOOGLE_DRIVE_PARENT_FOLDER=Applications


# ------------------------------------------------------------------------------
# SCHEDULING — Informational (actual cron is in .github/workflows/automation.yml)
# ------------------------------------------------------------------------------

# IANA timezone name — used in logs and for reference
APP_TIMEZONE=Asia/Dhaka

# Cron expression in UTC (this value is for documentation; edit the workflow YAML
# to actually change the schedule)
# "0 19 * * *" = 1:00 AM Bangladesh Standard Time (UTC+6)
CRON_SCHEDULE=0 19 * * *


# ------------------------------------------------------------------------------
# OPENAI SETTINGS
# ------------------------------------------------------------------------------

# Model to use for cover letter and email generation
# gpt-4o-mini is cost-efficient and high quality for this use case
# Alternatives: gpt-4.1-mini, gpt-4o
OPENAI_MODEL=gpt-4o-mini

# Generation temperature (0.0 = deterministic, 1.0 = creative)
# 0.7 balances professionalism with natural variation across applications
OPENAI_TEMPERATURE=0.7


# ------------------------------------------------------------------------------
# PROCESSING LIMITS
# ------------------------------------------------------------------------------

# Maximum number of "not applied" rows to process per workflow run
# Increase carefully — each job costs ~3-5 OpenAI API calls
MAX_JOBS_PER_RUN=10

# Seconds to sleep between processing consecutive jobs
# Prevents burst rate-limiting across OpenAI and Google APIs
RATE_LIMIT_DELAY=2


# ------------------------------------------------------------------------------
# NETWORK TIMEOUTS (seconds)
# ------------------------------------------------------------------------------

# Timeout for general HTTP requests
REQUEST_TIMEOUT=20

# Timeout specifically for job-page scraping (allow more for slow job boards)
SCRAPE_TIMEOUT=30


# ------------------------------------------------------------------------------
# RETRY COUNTS
# ------------------------------------------------------------------------------

# Number of retry attempts for OpenAI API calls
OPENAI_RETRIES=3

# Number of retry attempts for Google Sheets / Drive API calls
GOOGLE_RETRIES=3

# Number of retry attempts for web scraping
SCRAPE_RETRIES=2


# ------------------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG locally to see all details; INFO is fine for GitHub Actions
LOG_LEVEL=INFO


# ------------------------------------------------------------------------------
# FILE SYSTEM PATHS (relative to project root)
# ------------------------------------------------------------------------------

# Where generated .md and .docx files are saved locally
OUTPUT_DIR=output

# Where daily log files are written
LOGS_DIR=logs

# Where optimized resume profiles (.txt) are stored
RESUMES_DIR=resumes

# Where raw PDF resumes are placed for preprocessing
RAW_RESUMES_DIR=raw_resumes
